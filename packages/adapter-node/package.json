{
  "name": "@chronicle/adapter-node",
  "version": "0.1.0",
  "description": "Chronicle Adapter for Node.js Projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "@chronicle/agent": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@chronicle/agent": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
